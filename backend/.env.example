# ==============================================================================
# AgenticForge — Backend Environment Variable Reference
# ==============================================================================
# DO NOT commit a populated .env file. This file is the ONLY env file that
# belongs in source control. Copy it to `.env` and fill in real values.
#
#   cp .env.example .env
#
# Secrets are injected at runtime via your container platform (Koyeb, Fly.io,
# Railway) or through a secrets manager (e.g. Doppler, AWS Secrets Manager).
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. APPLICATION METADATA
# ------------------------------------------------------------------------------
PROJECT_NAME="AgenticForge"
API_V1_STR="/api/v1"

# Runtime environment: 'development' | 'production'
# Controls: SQLite vs PostgreSQL, CORS policy, log verbosity.
ENVIRONMENT="development"

# Public URL of the deployed frontend — used by Stripe redirects,
# GitHub OAuth callbacks, and password reset emails.
FRONTEND_URL="http://localhost:5173"

# Comma-separated list of allowed CORS origins (JSON list format)
# Production example: ["https://agenticforge.vercel.app"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ------------------------------------------------------------------------------
# 2. JWT / AUTH SECRETS
# CRITICAL: SECRET_KEY signs all JWT access + refresh tokens.
# Rotate it immediately if compromised — all existing sessions are invalidated.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------------------------
SECRET_KEY="REPLACE_WITH_64_CHAR_HEX_STRING_DO_NOT_USE_DEFAULT"
ALGORITHM="HS256"

# ------------------------------------------------------------------------------
# 3. BYOK FERNET ENCRYPTION KEY
# CRITICAL: This key encrypts user-supplied LLM API keys stored in the DB.
# If rotated without re-encrypting the DB, all stored BYOK keys become
# permanently unreadable. Generate a valid Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ------------------------------------------------------------------------------
ENCRYPTION_KEY="REPLACE_WITH_FERNET_BASE64_KEY_44_CHARS_ENDING_WITH_EQUALS"

# ------------------------------------------------------------------------------
# 4. DATABASE CONFIGURATION
# Development: SQLite file created automatically.
# Production: Must set ENVIRONMENT=production AND provide SUPABASE_DATABASE_URL.
#   The app.db.database module uses SUPABASE_DATABASE_URL when ENVIRONMENT=production.
#
# LangGraph AsyncSqliteSaver (main.py lifespan) also reads DATABASE_URL — see
# Phase 3 notes in DevSecOps plan for the PostgresSQL transition path.
# ------------------------------------------------------------------------------
DATABASE_URL="sqlite:///./agentic_forge.db"

# PostgreSQL connection string (Supabase Transaction Pooler recommended)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_DATABASE_URL=""

# ------------------------------------------------------------------------------
# 5. PLATFORM LLM KEYS (Fallback / Server-Level)
# These are used ONLY when a user has NOT configured a BYOK key via /users/settings.
# Users can override per-provider via the BYOK encrypted_api_key column.
# ------------------------------------------------------------------------------
GROQ_API_KEY="gsk_REPLACE_WITH_YOUR_GROQ_API_KEY"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ------------------------------------------------------------------------------
# 6. STRIPE BILLING
# STRIPE_API_KEY:          Secret key from Stripe dashboard (starts with sk_live_ or sk_test_)
# STRIPE_WEBHOOK_SECRET:   Signing secret from a registered Stripe webhook endpoint.
#                          Used in billing.py to verify Stripe-Signature header.
#                          Get from: Stripe Dashboard > Webhooks > [endpoint] > Signing Secret
# ------------------------------------------------------------------------------
STRIPE_API_KEY="sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SIGNING_SECRET"

# ------------------------------------------------------------------------------
# 7. GITHUB INTEGRATION
# GITHUB_ACCESS_TOKEN:    Server-level PAT for the /git/commit endpoint (PyGithub).
#                         Scope required: repo (full control of private repositories)
# GITHUB_CLIENT_ID:       OAuth App Client ID for the /git/github/login OAuth flow.
# GITHUB_CLIENT_SECRET:   OAuth App Client Secret for the /git/github/callback exchange.
# GITHUB_REDIRECT_URI:    Must exactly match the registered callback URL in your GitHub OAuth App.
# ------------------------------------------------------------------------------
GITHUB_ACCESS_TOKEN=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="http://localhost:8000/api/v1/git/github/callback"

# ------------------------------------------------------------------------------
# 8. CLOUD DEPLOYMENT TOKENS (used by /deploy endpoint)
# VERCEL_ACCESS_TOKEN:    From Vercel Dashboard > Account > Tokens
# NETLIFY_ACCESS_TOKEN:   From Netlify Dashboard > User Settings > Applications > Personal access tokens
# ------------------------------------------------------------------------------
VERCEL_ACCESS_TOKEN=""
NETLIFY_ACCESS_TOKEN=""

# ------------------------------------------------------------------------------
# 9. EMAIL PROVIDER (SendGrid)
# Used by auth.py /forgot-password to dispatch password reset links.
# Falls back to console logging if not set (development mode).
# ------------------------------------------------------------------------------
SENDGRID_API_KEY=""

# ------------------------------------------------------------------------------
# 10. LANGCHAIN / LANGSMITH OBSERVABILITY (Optional but Recommended)
# LangSmith traces every LangGraph node execution for debugging & cost auditing.
# LANGCHAIN_TRACING_V2:  Set "true" to enable tracing.
# LANGCHAIN_API_KEY:     From smith.langchain.com > Settings > API Keys
# LANGCHAIN_PROJECT:     Project name visible in LangSmith UI.
# ------------------------------------------------------------------------------
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="AgenticForge"
