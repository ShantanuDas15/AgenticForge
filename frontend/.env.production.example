VITE_APP_NAME="AgenticForge"

# Replace these placeholders with your actual production backend URLs in your
# hosting dashboard. Do not hardcode them in a committed file.
VITE_API_BASE_URL="https://your-production-backend.com/api/v1"
VITE_WS_BASE_URL="wss://your-production-backend.com/api/v1"
