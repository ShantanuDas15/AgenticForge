# ==============================================================================
# AgenticForge — Frontend .gitignore
# Scope: /AgenticForge/frontend/.gitignore
# Stack: React 19, Vite 8, Zustand, @xyflow/react, TailwindCSS, Framer Motion
# ==============================================================================

# ------------------------------------------------------------------------------
# CRITICAL: Environment & Secret Files — NEVER commit
# Vite exposes VITE_* vars to the browser bundle. Any .env.local or
# .env.production with real backend URLs, auth tokens, or API keys must
# never be committed to a public repository.
# ------------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging

# ------------------------------------------------------------------------------
# Node Dependencies
# node_modules can exceed 300MB. It is always regenerated via `npm install`.
# ------------------------------------------------------------------------------
node_modules/

# ------------------------------------------------------------------------------
# Vite Build Output
# dist/ is the production bundle generated by `vite build`.
# dist-ssr/ is the server-side rendering build output.
# Both are deployment artifacts — they belong in CI, not in source control.
# ------------------------------------------------------------------------------
dist/
dist-ssr/
build/
.vite/

# ------------------------------------------------------------------------------
# Vite Cache (local dev-server cache, not needed in VCS)
# ------------------------------------------------------------------------------
.vite-cache/

# ------------------------------------------------------------------------------
# TypeScript Build Info
# ------------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# ------------------------------------------------------------------------------
# Test Artifacts
# ------------------------------------------------------------------------------
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/
playwright-report/
test-results/

# ------------------------------------------------------------------------------
# Storybook (if adopted in future)
# ------------------------------------------------------------------------------
storybook-static/

# ------------------------------------------------------------------------------
# Editor & IDE
# ------------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# Package Manager Lockfiles
# package-lock.json — COMMIT this (ensures reproducible installs for npm).
# If using pnpm or yarn, adjust accordingly.
# ------------------------------------------------------------------------------
# package-lock.json  ← keep committed

# ------------------------------------------------------------------------------
# OS Artifacts
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
